# ───────────────────────────────────────────────────────────────────
# REQUIRED: point at any OpenAI-compatible endpoint. Default pattern
# is the host's Ollama:
#   OLLAMA_BASE_URL=http://host.docker.internal:11434/v1   (Linux/Mac/Win)
#   OLLAMA_BASE_URL=http://192.168.1.x:11434/v1            (LAN IP)
#
# Used by Aider, Continue, Kilo Code, and other OpenAI-compatible CLIs
# inside the sandbox. The Claude Code CLI (which speaks the Anthropic
# protocol) will only work if you set ANTHROPIC_BASE_URL to a real
# Anthropic-compatible gateway — Ollama alone is not enough.
# ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=

# REQUIRED: default coding model for Aider et al. Must already be pulled
# in your Ollama instance: `ollama pull <name>`.
LLM_MODEL=

# Optional: override Anthropic endpoint for the Claude Code CLI.
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_AUTH_TOKEN=sk-ant-...

# ───────────────────────────────────────────────────────────────────
# Host port mappings.
# ───────────────────────────────────────────────────────────────────
APP_PORT=8080

# ───────────────────────────────────────────────────────────────────
# MCP tool gateway (bundled by default — see docker-compose.yml).
# The bundled bridge runs the IDE-side MCP servers (filesystem, fetch,
# memory, sequential_thinking) behind an HTTP endpoint. The Claude
# Code / Cline / Kilo Code MCP configs in sandbox/mcp-config.json and
# ide/cline-mcp-settings.json point at it. To use your own MCP gateway,
# edit those JSON files and start with the byo override to skip the
# bundled bridge.
# ───────────────────────────────────────────────────────────────────

# Langfuse observability (optional — BYO).
# LANGFUSE_HOST=http://my-langfuse:3000
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...

# ───────────────────────────────────────────────────────────────────
# Optional HTTPS reverse proxy (--profile proxy).
# ───────────────────────────────────────────────────────────────────
DEMO_HOSTNAME=localhost
HTTP_PORT=8081
HTTPS_PORT=8443
